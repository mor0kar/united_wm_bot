# Discord Webhook
# Channel > Bearbeiten > Integrationen > Webhooks > Neuer Webhook > "Webhook-URL kopieren"
# Kein Bot-Token nötig — der Bot postet nur, er hört nicht zu.
DISCORD_WEBHOOK_URL=     # z.B. https://discord.com/api/webhooks/123456789/abcdef...

# football-data.org (kostenlos, Registrierung unter football-data.org)
FOOTBALL_DATA_API_KEY=   # API Key nach Registrierung

# Optional
LOG_LEVEL=info           # debug | info | warn | error (Default: info)

# Status-Seite: ohne Token sind die manuellen Trigger-Buttons deaktiviert
# (Status-Anzeige funktioniert trotzdem). Frei wählbares Geheimnis setzen,
# um die Buttons "Digest posten" / "Reminder-Check" / "Ergebnis-Check" zu nutzen.
DASHBOARD_TOKEN=         # optional, frei wählbar
